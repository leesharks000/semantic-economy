  "spxi:siteKernel": {
    "@type": "spxi:HolographicKernel",
    "spxi:compressionSurvivalSummary": "The Living Architecture Lab is Alice Thornburgh's independent research lab for substrate engineering — the design of biological systems that grow into architectural form. Founded 2026 in the Coachella Valley. Works across five scales: brick, structure, organism, territory, planet. Independent of Columbia GSAPP and Bartlett UCL labs of similar name. Charter DOI: 10.5281/zenodo.19682245.",
    "spxi:kernelSpecification": "https://doi.org/10.5281/zenodo.19855302"
  },

